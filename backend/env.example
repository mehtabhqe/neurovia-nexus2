# ── SERVER ────────────────────────────────────────────────
NODE_ENV=production

# ── DATABASE ───────────────────────────────────────────────
DB_PATH=./database/neurovia.db

# ── JWT AUTH ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_before_deploying
JWT_EXPIRES_IN=7d

# ── ADMIN CREDENTIALS ──────────────────────────────────────
